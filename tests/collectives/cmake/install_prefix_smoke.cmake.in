# Root CTest smoke for consuming collectives from an install prefix.
#

set(TILEXR_ROOT_SOURCE_DIR "@CMAKE_SOURCE_DIR@")
set(TILEXR_ROOT_BINARY_DIR "@CMAKE_BINARY_DIR@")
set(TILEXR_COLLECTIVES_TEST_SOURCE_DIR "@CMAKE_SOURCE_DIR@/tests/collectives")
set(TILEXR_SMOKE_INSTALL_PREFIX "@CMAKE_BINARY_DIR@/tilexr_collectives_ctest_install")
set(TILEXR_SMOKE_BUILD_DIR "@CMAKE_BINARY_DIR@/collectives_install_smoke_build")
set(TILEXR_SMOKE_INSTALL_LIBDIR "@CMAKE_INSTALL_LIBDIR@")
set(TILEXR_SMOKE_INSTALL_INCLUDEDIR "@CMAKE_INSTALL_INCLUDEDIR@")
set(TILEXR_SMOKE_ASCEND_HOME_PATH "@ASCEND_HOME_PATH@")
set(TILEXR_SMOKE_ARCH "@ARCH@")
set(TILEXR_SMOKE_ASCEND_DRIVER_PATH "@ASCEND_DRIVER_PATH@")
set(CMAKE_CTEST_COMMAND "@CMAKE_CTEST_COMMAND@")

if(IS_ABSOLUTE "${TILEXR_SMOKE_INSTALL_LIBDIR}")
    set(TILEXR_SMOKE_INSTALL_LIB_SEARCH_DIR "${TILEXR_SMOKE_INSTALL_LIBDIR}")
else()
    set(TILEXR_SMOKE_INSTALL_LIB_SEARCH_DIR "${TILEXR_SMOKE_INSTALL_PREFIX}/${TILEXR_SMOKE_INSTALL_LIBDIR}")
endif()
set(TILEXR_SMOKE_LD_LIBRARY_PATH "${TILEXR_SMOKE_INSTALL_LIB_SEARCH_DIR}")
if(DEFINED ENV{LD_LIBRARY_PATH} AND NOT "$ENV{LD_LIBRARY_PATH}" STREQUAL "")
    set(TILEXR_SMOKE_LD_LIBRARY_PATH "${TILEXR_SMOKE_LD_LIBRARY_PATH}:$ENV{LD_LIBRARY_PATH}")
endif()

file(REMOVE_RECURSE "${TILEXR_SMOKE_INSTALL_PREFIX}" "${TILEXR_SMOKE_BUILD_DIR}")

message(STATUS "Building root project for TileXR collectives smoke")
execute_process(
    COMMAND "${CMAKE_COMMAND}" --build "${TILEXR_ROOT_BINARY_DIR}"
    RESULT_VARIABLE tilexr_smoke_result
)
if(NOT tilexr_smoke_result EQUAL 0)
    message(FATAL_ERROR "Failed to build root TileXR project for collectives install-prefix smoke")
endif()

message(STATUS "Installing TileXR collectives smoke prefix with cmake --install")
execute_process(
    COMMAND "${CMAKE_COMMAND}" --install "${TILEXR_ROOT_BINARY_DIR}" --prefix "${TILEXR_SMOKE_INSTALL_PREFIX}"
    RESULT_VARIABLE tilexr_smoke_result
)
if(NOT tilexr_smoke_result EQUAL 0)
    message(FATAL_ERROR "cmake --install failed for collectives install-prefix smoke")
endif()

find_program(TILEXR_READELF readelf)
if(TILEXR_READELF)
    find_library(TILEXR_SMOKE_COLLECTIVES_LIB tilexr-collectives
        HINTS
        "${TILEXR_SMOKE_INSTALL_LIB_SEARCH_DIR}"
        NO_DEFAULT_PATH
    )
    if(NOT TILEXR_SMOKE_COLLECTIVES_LIB)
        message(FATAL_ERROR
            "Installed libtilexr-collectives.so not found under ${TILEXR_SMOKE_INSTALL_LIB_SEARCH_DIR}"
        )
    endif()

    message(STATUS "Checking libtilexr-collectives.so DT_NEEDED dependency with readelf -d")
    execute_process(
        COMMAND "${TILEXR_READELF}" -d "${TILEXR_SMOKE_COLLECTIVES_LIB}"
        RESULT_VARIABLE tilexr_smoke_result
        OUTPUT_VARIABLE tilexr_smoke_readelf_output
        ERROR_VARIABLE tilexr_smoke_readelf_error
    )
    if(NOT tilexr_smoke_result EQUAL 0)
        message(FATAL_ERROR
            "readelf -d failed for ${TILEXR_SMOKE_COLLECTIVES_LIB}: ${tilexr_smoke_readelf_error}"
        )
    endif()
    if(NOT tilexr_smoke_readelf_output MATCHES "Shared library: \\[libtile-comm\\.so\\]")
        message(FATAL_ERROR
            "Installed libtilexr-collectives.so is missing DT_NEEDED for libtile-comm.so:\n"
            "${tilexr_smoke_readelf_output}"
        )
    endif()
else()
    message(STATUS "readelf not found; skipping libtilexr-collectives.so DT_NEEDED smoke check")
endif()

message(STATUS "Configuring standalone collectives tests from install prefix")
execute_process(
    COMMAND "${CMAKE_COMMAND}" -S "${TILEXR_COLLECTIVES_TEST_SOURCE_DIR}" -B "${TILEXR_SMOKE_BUILD_DIR}"
        "-DTILEXR_INSTALL_PREFIX=${TILEXR_SMOKE_INSTALL_PREFIX}"
        "-DTILEXR_INSTALL_LIBDIR=${TILEXR_SMOKE_INSTALL_LIBDIR}"
        "-DTILEXR_INSTALL_INCLUDEDIR=${TILEXR_SMOKE_INSTALL_INCLUDEDIR}"
        "-DASCEND_HOME_PATH=${TILEXR_SMOKE_ASCEND_HOME_PATH}"
        "-DARCH=${TILEXR_SMOKE_ARCH}"
        "-DASCEND_DRIVER_PATH=${TILEXR_SMOKE_ASCEND_DRIVER_PATH}"
    RESULT_VARIABLE tilexr_smoke_result
)
if(NOT tilexr_smoke_result EQUAL 0)
    message(FATAL_ERROR "Failed to configure standalone collectives tests from install prefix")
endif()

message(STATUS "Building standalone collectives tests from install prefix")
execute_process(
    COMMAND "${CMAKE_COMMAND}" --build "${TILEXR_SMOKE_BUILD_DIR}"
    RESULT_VARIABLE tilexr_smoke_result
)
if(NOT tilexr_smoke_result EQUAL 0)
    message(FATAL_ERROR "Failed to build standalone collectives tests from install prefix")
endif()

message(STATUS "Running standalone collectives install-prefix tests")
execute_process(
    COMMAND "${CMAKE_COMMAND}" -E env
        "LD_LIBRARY_PATH=${TILEXR_SMOKE_LD_LIBRARY_PATH}"
        "${CMAKE_CTEST_COMMAND}" --test-dir "${TILEXR_SMOKE_BUILD_DIR}" --output-on-failure
    RESULT_VARIABLE tilexr_smoke_result
)
if(NOT tilexr_smoke_result EQUAL 0)
    message(FATAL_ERROR "Standalone collectives install-prefix tests failed")
endif()
